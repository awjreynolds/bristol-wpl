{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/bristol-wpl/schemas/spatial-metadata.schema.json",
  "title": "Spatial Dataset Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_id",
    "title",
    "publisher",
    "licence",
    "storage_path",
    "spatial_reference_system",
    "geometry_type",
    "lineage_source_ids",
    "data_classification",
    "qa_status"
  ],
  "properties": {
    "dataset_id": {
      "type": "string",
      "pattern": "^SPATIAL-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "data_owner": {
      "type": "string"
    },
    "licence": {
      "type": "string"
    },
    "licence_constraints": {
      "type": "string"
    },
    "acquisition_date": {
      "type": "string",
      "format": "date"
    },
    "version": {
      "type": "string"
    },
    "storage_path": {
      "type": "string"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "spatial_reference_system": {
      "type": "string"
    },
    "geometry_type": {
      "type": "string",
      "enum": ["point", "line", "polygon", "raster", "table", "mixed"]
    },
    "coverage_area": {
      "type": "string"
    },
    "lineage_source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^SRC-[A-Z0-9-]+$"
      }
    },
    "processing_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "tool_or_agent", "date"],
        "properties": {
          "step": {
            "type": "string"
          },
          "tool_or_agent": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "output_ref": {
            "type": "string"
          }
        }
      }
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "restricted", "personal_data", "special_category_data"]
    },
    "personal_data_flag": {
      "type": "boolean"
    },
    "restrictions": {
      "type": "string"
    },
    "qa_status": {
      "type": "string",
      "enum": ["not_checked", "checked_with_conditions", "passed", "failed"]
    },
    "qa_notes": {
      "type": "string"
    }
  }
}
