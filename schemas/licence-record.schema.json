{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/bristol-wpl/schemas/licence-record.schema.json",
  "title": "WPL Licence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "licence_id",
    "premises_reference",
    "liable_party",
    "boundary_option_id",
    "licensed_non_exempt_places",
    "charge_period",
    "licence_status",
    "source_ids"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "licence_status": {
            "const": "issued"
          }
        }
      },
      "then": {
        "required": ["issue_control"]
      }
    }
  ],
  "properties": {
    "licence_id": {
      "type": "string",
      "pattern": "^LIC-[A-Z0-9-]+$"
    },
    "premises_reference": {
      "$ref": "parking-inventory.schema.json#/properties/premises_reference"
    },
    "boundary_option_id": {
      "type": "string"
    },
    "liable_party": {
      "type": "object",
      "additionalProperties": false,
      "required": ["party_type", "organisation_name", "liability_basis"],
      "properties": {
        "party_type": {
          "type": "string",
          "enum": ["occupier", "third_party_parking_provider", "other"]
        },
        "organisation_name": {
          "type": "string"
        },
        "liability_basis": {
          "type": "string",
          "description": "Basis for charge liability, including evidence of arrangements with a parking provider where relevant."
        },
        "evidence_ref": {
          "type": "string"
        }
      }
    },
    "licensed_non_exempt_places": {
      "type": "integer",
      "minimum": 0
    },
    "exemptions_claimed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exemption_type", "places", "evidence_ref", "decision_status"],
        "properties": {
          "exemption_type": {
            "type": "string"
          },
          "places": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_ref": {
            "type": "string"
          },
          "decision_status": {
            "type": "string",
            "enum": ["accepted", "rejected", "under_review", "withdrawn"]
          }
        }
      }
    },
    "charge_period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "licence_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition_id", "condition_text"],
        "properties": {
          "condition_id": {
            "type": "string"
          },
          "condition_text": {
            "type": "string"
          }
        }
      }
    },
    "charge_calculation_ref": {
      "type": "string"
    },
    "licence_status": {
      "type": "string",
      "enum": ["draft", "issued", "varied", "cancelled", "expired", "refused", "under_review"]
    },
    "issue_control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_ref", "signoff_ref", "issue_scope"],
      "properties": {
        "decision_ref": {
          "type": "string",
          "description": "Formal decision, delegated authority or simulation reference authorising licence issue."
        },
        "signoff_ref": {
          "type": "string",
          "description": "Simulation sign-off ID or real-world operating authority reference."
        },
        "issue_scope": {
          "type": "string",
          "enum": ["simulation_only", "real_world_operational"]
        }
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^SRC-[A-Z0-9-]+$"
      }
    }
  }
}
