{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/bristol-wpl/schemas/parking-inventory.schema.json",
  "title": "Workplace Parking Inventory Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "inventory_id",
    "premises_reference",
    "site_name",
    "boundary_option_id",
    "workplace_parking_places_total",
    "count_method",
    "count_confidence",
    "source_ids",
    "data_classification",
    "status"
  ],
  "properties": {
    "inventory_id": {
      "type": "string",
      "pattern": "^WPI-[A-Z0-9-]+$"
    },
    "premises_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_type", "reference_value"],
      "properties": {
        "reference_type": {
          "type": "string",
          "enum": ["UPRN", "LLPG", "VOA", "planning_reference", "manual_reference"]
        },
        "reference_value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "site_name": {
      "type": "string",
      "minLength": 1
    },
    "address_summary": {
      "type": "string"
    },
    "occupier_or_employer_name": {
      "type": "string",
      "description": "Organisation name only. Do not store personal contact data in normal Git paths."
    },
    "third_party_parking_provider": {
      "type": "string",
      "description": "Organisation name where parking-place liability may sit with a provider rather than the occupier."
    },
    "geometry_ref": {
      "type": "string",
      "description": "Pointer to controlled spatial dataset feature, not inline geometry."
    },
    "boundary_option_id": {
      "type": "string"
    },
    "inside_boundary": {
      "type": "boolean"
    },
    "workplace_parking_places_total": {
      "type": "integer",
      "minimum": 0
    },
    "non_exempt_places_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "exempt_place_breakdown": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exemption_type", "places", "evidence_ref"],
        "properties": {
          "exemption_type": {
            "type": "string"
          },
          "places": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_ref": {
            "type": "string"
          }
        }
      }
    },
    "count_method": {
      "type": "string",
      "enum": ["site_survey", "employer_return", "planning_record", "aerial_imagery", "business_rates_linkage", "modelled_estimate", "mixed", "unknown"]
    },
    "count_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unusable"]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^SRC-[A-Z0-9-]+$"
      }
    },
    "lawful_basis_note": {
      "type": "string"
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "restricted", "personal_data", "special_category_data"]
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "verified", "contested", "excluded", "superseded"]
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewed_by_agent": {
          "type": "string"
        },
        "review_date": {
          "type": "string",
          "format": "date"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
