flowchart TD
    A["Raw and extracted evidence<br/>evidence/raw and extraction manifests"] --> B["Source notes<br/>source-use controls only"]
    B --> C["Claim summaries<br/>current claim-matrix controls only"]
    C --> D["Editable section templates<br/>OBC FBC statutory officer public"]
    D --> E["Future assembled OBC/FBC/statutory outputs<br/>BLOCKED"]

    E -. "OBC gate not passed" .-> OBC["Stage 7 OBC gate<br/>BLOCKED"]
    E -. "FBC/statutory gate not passed" .-> FBC["Stage 11 FBC/statutory gate<br/>BLOCKED"]
    D -. "No authored officer-distribution PDFs" .-> PDF["PDF output<br/>PROHIBITED except downloaded raw evidence"]

    classDef blocked fill:#ffdddd,stroke:#990000,color:#111111;
    classDef control fill:#fff4cc,stroke:#996600,color:#111111;
    classDef current fill:#ddf4ff,stroke:#005f99,color:#111111;

    class A,B,C,D control;
    class E,OBC,FBC,PDF blocked;
